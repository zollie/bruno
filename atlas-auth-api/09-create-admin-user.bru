meta {
  name: Create Admin User
  type: http
  seq: 9
}

post {
  url: https://api-blue.us-east-1.atlas.nonprod.aws.janeisis.com/auth/api/users
  body: json
  auth: none
}

headers {
  Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6ImFwaS1rZXktaHMyNTYifQ..j-Q2r9ainAIh35tjP-xEu80f_eGKWLnRJFDdOijUGEQ
  Content-Type: application/json
}

body:json {
  {
    "email": "zollie@janeisis.com  ",
    "firstName": "Zollie",
    "lastName": "Badass",
    "displayName": "Bad Motherfucker",
    "org": "atlas",
    "tenants": ["*"],
    "roles": ["atlas_admin"],
    "departments": ["platform"],
    "identityMode": "link_existing",
    "enabled": true,
    "emailVerified": true
  }
}

assert {
  res.status: eq 201
}

script:post-response {
  const body = res.getBody();
  if (body && body.userId) {
    bru.setVar("adminUserId", body.userId);
  }
}
