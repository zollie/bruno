meta {
  name: Onboard Tenant
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/auth/api/tenants/onboard
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "tenantName": "{{tenantName}}",
    "tenantId": "{{tenantId}}"
  }
}

assert {
  res.status: eq 201
}

script:post-response {
  const body = res.getBody();
  if (body && body.tenantId) {
    bru.setVar("tenantId", body.tenantId);
  }
}
