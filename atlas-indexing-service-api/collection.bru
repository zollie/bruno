docs {
  # Atlas Indexing Service API

  This collection targets the `/v1/index` S3 indexing route.

  Notes:
  - Uses service-level `tenant_id` in request body.
  - Send the token as `Authorization: Bearer {{token}}`.
}

vars {
  baseUrl: http://localhost:8081
  token: replace-with-token
  tenantId: replace-with-tenant-id
  s3Bucket: replace-with-s3-bucket
  s3Key: replace-with-s3-key
  sourceFilename: replace-with-source-filename
  contentType: text/plain
}
