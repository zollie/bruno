docs {
  # Atlas Indexing API

  This collection targets the Atlas `/indexing` module.

  Notes:
  - Tenant in path must match the JWT tenant claim, or the JWT must contain `tenants: ["*"]`.
  - Create ingestion stores returned `jobId` for later requests.
}

vars {
  baseUrl: http://localhost:8080
  tenantId: replace-with-onboarded-tenant-id
  token: replace-with-atlas-context-jwt
  jobId: replace-after-create
}
