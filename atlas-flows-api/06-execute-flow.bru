meta {
  name: Execute Flow
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/flows/tenants/{{tenantId}}/flows/{{flowId}}/executions
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

assert {
  res.status: eq 201
}

script:post-response {
  const body = res.getBody();
  if (body && body.executionId) {
    bru.setVar("executionId", body.executionId);
  }
}

tests {
  test("response contains executionId", function() {
    const body = res.getBody();
    expect(body.executionId).to.not.equal(null);
  });
}
