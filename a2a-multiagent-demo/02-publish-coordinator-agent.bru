meta {
  name: Publish Coordinator Agent
  type: http
  seq: 2
}

post {
  url: {{registryBaseUrl}}/agents
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "cardUrl": "{{coordinatorCardUrl}}"
  }
}

assert {
  res.status: eq 201
}

script:post-response {
  const body = res.getBody();
  if (body && body.agentId) {
    bru.setVar("coordinatorAgentRegistryId", body.agentId);
  }
}
