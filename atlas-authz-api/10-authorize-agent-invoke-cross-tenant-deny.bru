meta {
  name: Authorize Agent Invoke Cross-Tenant Deny
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/authz/tenants/{{tenantId}}/authorize
  body: json
}

headers {
  Authorization: Bearer {{token}}
  X-Tenant-ID: {{tenantId}}
  Content-Type: application/json
}

body:json {
  {
    "jwtClaims": {
      "sub": "{{userId}}",
      "tenant_id": "{{crossTenantId}}",
      "tenants": ["{{crossTenantId}}"]
    },
    "action": {
      "name": "agent.invoke",
      "input": {
        "target_agent_id": "{{agentResourceId}}"
      }
    },
    "resource": {
      "id": "{{agentResourceId}}",
      "type": "Atlas::Agent",
      "attrs": {
        "tenant_id": "{{tenantId}}"
      }
    },
    "context": {}
  }
}

tests {
  test("status is 200 or 404", function() {
    const status = typeof res.getStatus === "function" ? res.getStatus() : res.status;
    expect([200, 404]).to.include(status);
  });

  test("allow=false when policy bundle exists", function() {
    const status = typeof res.getStatus === "function" ? res.getStatus() : res.status;
    if (status === 200) {
      const body = res.getBody();
      expect(body.allow).to.equal(false);
    }
  });
}
