meta {
  name: Cancel Ingestion
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/indexing/tenants/{{tenantId}}/ingestions/{{jobId}}:cancel
  body: none
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("status is 202 or 409", function() {
    const status = typeof res.getStatus === "function" ? res.getStatus() : res.status;
    expect([202, 409]).to.include(status);
  });
}
