meta {
  name: Delete All Ingestions
  type: http
  seq: 7
}

delete {
  url: {{baseUrl}}/indexing/tenants/{{tenantId}}/ingestions
  body: none
}

headers {
  Authorization: Bearer {{token}}
}

assert {
  res.status: eq 200
}

tests {
  test("response includes deletedCount", function() {
    const body = res.getBody();
    expect(body).to.have.property("deletedCount");
  });
}
